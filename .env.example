# Core backend vars
DATABASE_URL=postgresql://postgres:password@host:5432/database_name
JWT_SECRET=replace-with-a-very-long-secret-32-characters-or-more
NEXT_PUBLIC_APP_URL=https://your-frontend-url.example.com
APP_URL=https://your-backend-url.example.com

# Optional external services
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="HQ INVESTMENT <no-reply@example.com>"

# Optional Railway automation / cron keys
CRON_SECRET=replace-with-a-strong-cron-secret
AUTOMATION_KEY=replace-with-a-strong-automation-key

# Optional payment webhook settings
PALMPESA_API_URL=https://api.palmpesa.com/v1/payments/stk-push
PALMPESA_API_KEY=replace-with-your-palmpesa-api-key

# Optional security settings
CORS_ORIGIN=*
