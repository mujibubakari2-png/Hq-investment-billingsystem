{
    "name": "hqinvestment-isp-monorepo",
    "version": "1.0.0",
    "description": "ISP Billing System - Multi-service monorepo",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "pnpm -r dev",
        "build": "pnpm --filter backend build",
        "start": "pnpm --filter backend start",
        "build:landing": "pnpm --filter landing-page build",
        "start:landing": "pnpm --filter landing-page start",
        "build:frontend": "pnpm --filter frontend build",
        "build:all": "CI=true NEXT_TELEMETRY_DISABLED=1 pnpm -r --workspace-concurrency=1 build",
        "start:all": "pnpm -r start"
    },
    "workspaces": [
        "backend",
        "frontend",
        "landing-page"
    ],
    "keywords": [
        "isp",
        "billing",
        "monorepo"
    ],
    "author": "HQ Investment",
    "license": "UNLICENSED"
}