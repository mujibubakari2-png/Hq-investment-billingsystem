{
    "name": "kenge-isp-monorepo",
    "version": "1.0.0",
    "description": "ISP Billing System - Multi-service monorepo",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "dev": "pnpm -r dev",
        "build": "pnpm --filter backend build",
        "start": "pnpm --filter backend start",
        "build:all": "pnpm -r build",
        "start:all": "pnpm -r start"
    },
    "workspaces": [
        "backend",
        "frontend",
        "landing-page"
    ],
    "keywords": [
        "isp",
        "billing",
        "monorepo"
    ],
