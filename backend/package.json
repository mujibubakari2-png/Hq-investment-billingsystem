{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "prisma generate && next build",
    "build:full": "prisma generate && next build",
    "start": "next start --hostname 127.0.0.1 --port ${PORT:-3000}",
    "start:droplet": "bash scripts/droplet-start.sh",
    "next:start": "next start --hostname 127.0.0.1 --port ${PORT:-3000}",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:check-migrations": "tsx scripts/check-migrations.js",
    "db:fix-migrations": "tsx scripts/fix-migrations.js",
    "db:generate": "prisma generate",
    "test": "node scripts/setup-test-db.js && jest --config jest.config.ts",
    "test:coverage": "node scripts/setup-test-db.js && jest --config jest.config.ts --coverage"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.1.11",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aria-query": "^5.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-path": "^3.1.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/d3-timer": "^3.0.2",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/prop-types": "^15.7.15",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@types/use-sync-external-store": "^0.0.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "lint-staged": "^16.4.0",
    "prisma": "7.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  }
}
