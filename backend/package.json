{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3001",
    "build": "prisma generate && node --max-old-space-size=1536 node_modules/next/dist/bin/next build",
    "build:full": "prisma generate && node --max-old-space-size=1536 node_modules/next/dist/bin/next build",
    "start": "next start --hostname 127.0.0.1 --port ${PORT:-3000}",
    "start:droplet": "bash scripts/droplet-start.sh",
    "next:start": "next start --hostname 127.0.0.1 --port ${PORT:-3000}",

    "db:seed": "tsx scripts/seed.ts",
    "db:migrate": "prisma migrate deploy",

    "db:check-migrations": "tsx scripts/check-migrations.js",
    "db:fix-migrations": "tsx scripts/fix-migrations.js",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "next": "15.1.11",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "7.7.0",
    "typescript": "^5"
  }
}
