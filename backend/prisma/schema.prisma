// Kenge ISP Billing System - Database Schema
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── SYSTEM USERS (login accounts for admins/agents) ─────────────────────────
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  fullName  String?
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(AGENT)
  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouchers  Voucher[]
  expenses  Expense[]
  otps      UserOtp[]

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model UserOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
  user      User?    @relation(fields: [email], references: [email])

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("user_otps")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

// ─── CLIENTS (ISP customers) ────────────────────────────────────────────────
model Client {
  id          String        @id @default(cuid())
  username    String        @unique
  fullName    String
  phone       String?
  email       String?
  serviceType ServiceType
  status      ClientStatus  @default(ACTIVE)
  accountType AccountType   @default(PERSONAL)
  macAddress  String?
  device      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  subscriptions Subscription[]
  transactions  Transaction[]
  invoices      Invoice[]
  smsMessages   SmsMessage[]

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("clients")
}

enum ServiceType {
  HOTSPOT
  PPPOE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  SUSPENDED
  BANNED
  DISABLED
  LIMITED
}

enum AccountType {
  PERSONAL
  BUSINESS
}

// ─── PACKAGES (service plans) ───────────────────────────────────────────────
model Package {
  id            String      @id @default(cuid())
  name          String
  type          ServiceType
  category      AccountType @default(PERSONAL)
  uploadSpeed   Float
  uploadUnit    String      @default("Mbps")
  downloadSpeed Float
  downloadUnit  String      @default("Mbps")
  price         Float
  duration      Int
  durationUnit  DurationUnit
  status        PackageStatus @default(ACTIVE)
  burstEnabled  Boolean     @default(false)
  hotspotType   HotspotType?
  devices       Int?        @default(1)
  paymentType   PaymentType @default(PREPAID)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  routerId      String?
  router        Router?     @relation(fields: [routerId], references: [id])

  subscriptions Subscription[]
  vouchers      Voucher[]

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("packages")
}

enum DurationUnit {
  MINUTES
  HOURS
  DAYS
  MONTHS
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

enum HotspotType {
  UNLIMITED
  DATA_CAPPED
}

enum PaymentType {
  PREPAID
  POSTPAID
}

// ─── SUBSCRIPTIONS (active/expired plans for clients) ───────────────────────
model Subscription {
  id          String             @id @default(cuid())
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  packageId   String
  package     Package            @relation(fields: [packageId], references: [id])
  routerId    String?
  router      Router?            @relation(fields: [routerId], references: [id])
  status      SubscriptionStatus @default(ACTIVE)
  method      String?
  activatedAt DateTime           @default(now())
  expiresAt   DateTime
  dataUsed    String?
  onlineStatus OnlineStatus?     @default(OFFLINE)
  syncStatus  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  EXTENDED
  SUSPENDED
}

enum OnlineStatus {
  ONLINE
  OFFLINE
}

// ─── TRANSACTIONS ───────────────────────────────────────────────────────────
model Transaction {
  id          String            @id @default(cuid())
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planName    String?
  amount      Float
  type        TransactionType   @default(MOBILE)
  method      String
  status      TransactionStatus @default(PENDING)
  reference   String            @unique
  expiryDate  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  MANUAL
  MOBILE
  VOUCHER
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
}

// ─── ROUTERS (MikroTik) ────────────────────────────────────────────────────
model Router {
  id          String       @id @default(cuid())
  name        String       @unique
  host        String
  username    String?      @default("admin")
  password    String?
  port        Int?         @default(8728)
  apiPort     Int?         @default(8728)
  type        String       @default("MikroTik")
  vpnMode     String?      @default("hybrid")
  description String?
  status      RouterStatus @default(OFFLINE)
  activeUsers Int          @default(0)
  cpuLoad     Float        @default(0)
  memoryUsed  Float        @default(0)
  uptime      String?
  lastSeen    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  packages      Package[]
  subscriptions Subscription[]
  equipments    Equipment[]
  vouchers      Voucher[]
  logs          RouterLog[]
  hotspotSettings HotspotSettings?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("routers")
}

enum RouterStatus {
  ONLINE
  OFFLINE
}

// ─── ROUTER ACTION LOGS ────────────────────────────────────────────────────
model RouterLog {
  id        String   @id @default(cuid())
  routerId  String
  router    Router   @relation(fields: [routerId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  status    String   @default("success")
  username  String?
  ipAddress String?
  createdAt DateTime @default(now())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("router_logs")
}

model HotspotSettings {
  id                  String   @id @default(cuid())
  routerId            String   @unique
  router              Router   @relation(fields: [routerId], references: [id], onDelete: Cascade)
  primaryColor        String   @default("#1a1a2e")
  accentColor         String   @default("#6366f1")
  selectedFont        String   @default("Inter")
  layout              String   @default("grid")
  enableAds           Boolean  @default(false)
  enableAnnouncement  Boolean  @default(true)
  enableRememberMe    Boolean  @default(true)
  companyName         String?
  customerCareNumber  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenantId            String?
  tenant              Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hotspot_settings")
}

// ─── EQUIPMENT ──────────────────────────────────────────────────────────────
model Equipment {
  id           String          @id @default(cuid())
  name         String
  type         String
  serialNumber String          @unique
  status       EquipmentStatus @default(ACTIVE)
  location     String?
  assignedTo   String?
  purchaseDate DateTime?
  notes        String?
  routerId     String?
  router       Router?         @relation(fields: [routerId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("equipments")
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ─── VOUCHERS ───────────────────────────────────────────────────────────────
model Voucher {
  id         String        @id @default(cuid())
  code       String        @unique
  packageId  String
  package    Package       @relation(fields: [packageId], references: [id])
  routerId   String?
  router     Router?       @relation(fields: [routerId], references: [id])
  status     VoucherStatus @default(UNUSED)
  createdById String
  createdBy  User          @relation(fields: [createdById], references: [id])
  usedBy     String?
  usedAt     DateTime?
  customer   Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

enum VoucherStatus {
  UNUSED
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

// ─── EXPENSES ───────────────────────────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  date        DateTime
  reference   String?
  receipt     String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ─── INVOICES ───────────────────────────────────────────────────────────────
model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount        Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  issuedDate    DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items InvoiceItem[]

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Float
  total       Float

  @@map("invoice_items")
}

enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
  DRAFT
}

// ─── SMS MESSAGES ───────────────────────────────────────────────────────────
model SmsMessage {
  id        String    @id @default(cuid())
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  recipient String
  message   String
  status    SmsStatus @default(PENDING)
  type      SmsType   @default(INDIVIDUAL)
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sms_messages")
}

enum SmsStatus {
  SENT
  FAILED
  PENDING
}

enum SmsType {
  BROADCAST
  INDIVIDUAL
}

// ─── MESSAGE TEMPLATES ──────────────────────────────────────────────────────
model MessageTemplate {
  id        String       @id @default(cuid())
  name      String
  content   String
  type      TemplateType @default(CUSTOM)
  variables String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("message_templates")
}

enum TemplateType {
  ACTIVATION
  EXPIRY
  PAYMENT
  CUSTOM
  REMINDER
}

// ─── PAYMENT CHANNELS ───────────────────────────────────────────────────────
model PaymentChannel {
  id            String        @id @default(cuid())
  name          String
  provider      String
  accountNumber String?
  apiKey        String?
  apiSecret     String?
  status        ChannelStatus @default(ACTIVE)
  config        Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payment_channels")
}

enum ChannelStatus {
  ACTIVE
  INACTIVE
}

// ─── SYSTEM SETTINGS ────────────────────────────────────────────────────────
model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String @default("general")

    tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("system_settings")
}


// ─── SAAS TENANT MODELS ───────────────────────────────────────────────────
model Tenant {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  phone       String?
  status      TenantStatus @default(ACTIVE)
  planId      String
  plan        SaasPlan     @relation(fields: [planId], references: [id])
  trialStart  DateTime?
  trialEnd    DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users             User[]
  clients           Client[]
  packages          Package[]
  subscriptions     Subscription[]
  transactions      Transaction[]
  routers           Router[]
  equipments        Equipment[]
  vouchers          Voucher[]
  expenses          Expense[]
  invoices          Invoice[]
  smsMessages       SmsMessage[]
  messageTemplates  MessageTemplate[]
  paymentChannels   PaymentChannel[]
  systemSettings    SystemSetting[]
  tenantInvoices    TenantInvoice[]
  tenantPayments    TenantPayment[]
  userOtps          UserOtp[]
  routerLogs        RouterLog[]
  hotspotSettings   HotspotSettings[]

  @@map("tenants")
}

enum TenantStatus {
  TRIALLING
  ACTIVE
  SUSPENDED
  CANCELLED
}

model SaasPlan {
  id          String   @id @default(cuid())
  name        String
  price       Float
  clientLimit Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants     Tenant[]
  invoices    TenantInvoice[]

  @@map("saas_plans")
}

model TenantInvoice {
  id            String              @id @default(cuid())
  invoiceNumber String              @unique
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId        String
  plan          SaasPlan            @relation(fields: [planId], references: [id])
  amount        Float
  status        TenantInvoiceStatus @default(PENDING)
  dueDate       DateTime
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  payments      TenantPayment[]

  @@map("tenant_invoices")
}

enum TenantInvoiceStatus {
  PENDING
  PAID
  EXPIRED
}

model TenantPayment {
  id            String         @id @default(cuid())
  invoiceId     String
  invoice       TenantInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount        Float
  transactionId String?        @unique
  paymentMethod String         @default("PALMPESA") // e.g. MIX_BY_YAS, AIRTEL_MONEY, HALOPESA, MPESA
  status        PaymentStatus  @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("tenant_payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
