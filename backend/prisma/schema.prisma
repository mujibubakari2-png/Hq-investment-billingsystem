generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  fullName  String?
  email     String     @unique
  password  String
  phone     String?
  role      Role       @default(AGENT)
  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenantId  String?
  expenses  Expense[]
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vouchers  Voucher[]

  @@index([tenantId])
  @@index([role])
  @@index([status])
  @@map("users")
}

model UserOtp {
  id        String   @id @default(cuid())
  email     String?
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("user_otps")
}

model Client {
  id            String         @id @default(cuid())
  username      String         @unique
  fullName      String
  phone         String?
  email         String?
  serviceType   ServiceType
  status        ClientStatus   @default(ACTIVE)
  accountType   AccountType    @default(PERSONAL)
  macAddress    String?
  device        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices      Invoice[]
  smsMessages   SmsMessage[]
  subscriptions Subscription[]
  transactions  Transaction[]

  @@index([tenantId])
  @@index([status])
  @@index([serviceType])
  @@index([createdAt])
  @@map("clients")
}

model Package {
  id            String         @id @default(cuid())
  name          String
  type          ServiceType
  category      AccountType    @default(PERSONAL)
  uploadSpeed   Float
  uploadUnit    String         @default("Mbps")
  downloadSpeed Float
  downloadUnit  String         @default("Mbps")
  price         Float
  duration      Int
  durationUnit  DurationUnit
  status        PackageStatus  @default(ACTIVE)
  burstEnabled  Boolean        @default(false)
  hotspotType   HotspotType?
  devices       Int?           @default(1)
  paymentType   PaymentType    @default(PREPAID)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  routerId      String?
  tenantId      String?
  router        Router?        @relation(fields: [routerId], references: [id])
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  vouchers      Voucher[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([routerId])
  @@map("packages")
}

model Subscription {
  id           String             @id @default(cuid())
  clientId     String
  packageId    String
  routerId     String?
  status       SubscriptionStatus @default(ACTIVE)
  method       String?
  activatedAt  DateTime           @default(now())
  expiresAt    DateTime
  dataUsed     String?
  onlineStatus OnlineStatus?      @default(OFFLINE)
  syncStatus   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenantId     String?
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  package      Package            @relation(fields: [packageId], references: [id])
  router       Router?            @relation(fields: [routerId], references: [id])
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Transaction {
  id         String            @id @default(cuid())
  clientId   String
  planName   String?
  amount     Float
  type       TransactionType   @default(MOBILE)
  method     String
  status     TransactionStatus @default(PENDING)
  reference  String            @unique
  expiryDate DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  tenantId   String?
  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Router {
  id               String           @id @default(cuid())
  name             String
  host             String
  username         String?          @default("admin")
  password         String?
  port             Int?             @default(8728)
  type             String           @default("MikroTik")
  status           RouterStatus     @default(OFFLINE)
  activeUsers      Int              @default(0)
  cpuLoad          Float            @default(0)
  memoryUsed       Float            @default(0)
  uptime           String?
  lastSeen         DateTime?
  accountingEnabled Boolean          @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime         @updatedAt
  tenantId         String?
  apiPort          Int?             @default(8728)
  description      String?
  vpnMode          String?          @default("hybrid")
  wgConfiguredAt   DateTime?
  wgEnabled        Boolean          @default(false)
  wgListenPort     Int?             @default(13231)
  wgPeerPublicKey  String?
  wgPresharedKey   String?
  wgPrivateKey     String?
  wgPublicKey      String?
  wgServerEndpoint String?
  wgTunnelIp       String?          @default("10.200.0.1")
  equipments       Equipment[]
  hotspotSettings  HotspotSettings?
  packages         Package[]
  logs             RouterLog[]
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions    Subscription[]
  vouchers         Voucher[]
  vpnUsers         VpnUser[]

  @@unique([name, tenantId])
  @@map("routers")
}

model RouterLog {
  id        String   @id @default(cuid())
  routerId  String
  action    String
  details   String?
  status    String   @default("success")
  username  String?
  ipAddress String?
  createdAt DateTime @default(now())
  tenantId  String?
  router    Router   @relation(fields: [routerId], references: [id], onDelete: Cascade)
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("router_logs")
}

model HotspotSettings {
  id                 String   @id @default(cuid())
  routerId           String   @unique
  primaryColor       String   @default("#1a1a2e")
  accentColor        String   @default("#6366f1")
  selectedFont       String   @default("Inter")
  layout             String   @default("grid")
  enableAds          Boolean  @default(false)
  enableAnnouncement Boolean  @default(true)
  enableRememberMe   Boolean  @default(true)
  companyName        String?
  customerCareNumber String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenantId           String?
  adMessage          String?  @default("🎉 Special offer! Get extra data on all packages today!")
  backendUrl         String?
  router             Router   @relation(fields: [routerId], references: [id], onDelete: Cascade)
  tenant             Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hotspot_settings")
}

model Equipment {
  id           String          @id @default(cuid())
  name         String
  type         String
  serialNumber String          @unique
  status       EquipmentStatus @default(ACTIVE)
  location     String?
  assignedTo   String?
  purchaseDate DateTime?
  notes        String?
  routerId     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenantId     String?
  router       Router?         @relation(fields: [routerId], references: [id])
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("equipments")
}

model Voucher {
  id          String        @id @default(cuid())
  code        String        @unique
  packageId   String
  routerId    String?
  status      VoucherStatus @default(UNUSED)
  createdById String
  usedBy      String?
  usedAt      DateTime?
  customer    Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenantId    String?
  createdBy   User          @relation(fields: [createdById], references: [id])
  package     Package       @relation(fields: [packageId], references: [id])
  router      Router?       @relation(fields: [routerId], references: [id])
  tenant      Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  date        DateTime
  reference   String?
  receipt     String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String?
  createdBy   User     @relation(fields: [createdById], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  amount        Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  issuedDate    DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenantId      String?
  items         InvoiceItem[]
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant        Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model SmsMessage {
  id        String    @id @default(cuid())
  clientId  String?
  recipient String
  message   String
  status    SmsStatus @default(PENDING)
  type      SmsType   @default(INDIVIDUAL)
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenantId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sms_messages")
}

model MessageTemplate {
  id        String       @id @default(cuid())
  name      String
  content   String
  type      TemplateType @default(CUSTOM)
  variables String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenantId  String?
  tenant    Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("message_templates")
}

model PaymentChannel {
  id            String        @id @default(cuid())
  name          String
  provider      String
  accountNumber String?
  apiKey        String?
  apiSecret     String?
  status        ChannelStatus @default(ACTIVE)
  config        Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenantId      String?
  tenant        Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payment_channels")
}

model SystemSetting {
  id       String  @id @default(cuid())
  key      String
  value    String
  group    String  @default("general")
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([key, tenantId])
  @@map("system_settings")
}

model Tenant {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  phone            String?
  status           TenantStatus      @default(ACTIVE)
  planId           String
  trialStart       DateTime?
  trialEnd         DateTime?
  licenseExpiresAt DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clients          Client[]
  equipments       Equipment[]
  expenses         Expense[]
  hotspotSettings  HotspotSettings[]
  invoices         Invoice[]
  messageTemplates MessageTemplate[]
  packages         Package[]
  paymentChannels  PaymentChannel[]
  radaccts         RadAcct[]
  radchecks        RadCheck[]
  radiusNas        RadiusNas[]
  radiusUsers      RadiusUser[]
  routerLogs       RouterLog[]
  routers          Router[]
  smsMessages      SmsMessage[]
  subscriptions    Subscription[]
  systemSettings   SystemSetting[]
  tenantInvoices   TenantInvoice[]
  tenantPayments   TenantPayment[]
  plan             SaasPlan          @relation(fields: [planId], references: [id])
  transactions     Transaction[]
  userOtps         UserOtp[]
  users            User[]
  vouchers         Voucher[]
  vpnUsers         VpnUser[]

  @@map("tenants")
}

model SaasPlan {
  id          String          @id @default(cuid())
  name        String
  price       Float
  clientLimit Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  invoices    TenantInvoice[]
  tenants     Tenant[]

  @@map("saas_plans")
}

model TenantInvoice {
  id            String              @id @default(cuid())
  invoiceNumber String              @unique
  tenantId      String
  planId        String
  packageMonths Int?
  amount        Float
  status        TenantInvoiceStatus @default(PENDING)
  dueDate       DateTime
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  plan          SaasPlan            @relation(fields: [planId], references: [id])
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments      TenantPayment[]

  @@map("tenant_invoices")
}

model TenantPayment {
  id            String        @id @default(cuid())
  invoiceId     String
  tenantId      String
  amount        Float
  transactionId String?       @unique
  paymentMethod String        @default("PALMPESA")
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       TenantInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_payments")
}

model VpnUser {
  id            String    @id @default(cuid())
  username      String
  password      String
  fullName      String?
  protocol      String    @default("L2TP")
  profile       String    @default("default")
  service       String    @default("l2tp")
  localAddress  String?
  remoteAddress String?
  status        String    @default("Active")
  routerId      String
  uptime        String?
  bytesIn       String?
  bytesOut      String?
  connectedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenantId      String?
  router        Router    @relation(fields: [routerId], references: [id])
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([username, tenantId])
  @@map("vpn_users")
}

model RadiusUser {
  id              String    @id @default(cuid())
  username        String
  password        String
  fullName        String?
  authType        String    @default("PAP")
  groupName       String    @default("default")
  status          String    @default("Active")
  speed           String?
  dataLimit       String?
  sessionTimeout  String?
  simultaneousUse Int       @default(1)
  nasIpAddress    String?
  framedIpAddress String?
  lastSeen        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([username, tenantId])
  @@map("radius_users")
}

model RadiusNas {
  id          String   @id @default(cuid())
  nasName     String
  shortName   String?
  type        String   @default("other")
  ports       Int      @default(0)
  secret      String
  server      String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([nasName, tenantId])
  @@map("radius_nas")
}

model RadCheck {
  id        Int     @id @default(autoincrement())
  username  String  @db.VarChar(64)
  attribute String  @default("Cleartext-Password") @db.VarChar(64)
  op        String  @default(":=") @db.VarChar(2)
  value     String  @db.VarChar(253)
  tenantId  String?
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([tenantId])
  @@index([tenantId, username])
  @@map("radcheck")
}

model RadAcct {
  radacctid          BigInt    @id @default(autoincrement())
  acctsessionid      String    @db.VarChar(64)
  acctuniqueid       String    @unique @db.VarChar(32)
  username           String    @db.VarChar(64)
  realm              String?   @db.VarChar(64)
  nasipaddress       String    @db.VarChar(15)
  nasportid          String?   @db.VarChar(32)
  nasporttype        String?   @db.VarChar(32)
  acctstarttime      DateTime?
  acctupdatetime     DateTime?
  acctstoptime       DateTime?
  acctinterval       Int?
  acctsessiontime    Int?
  acctauthentic      String?   @db.VarChar(32)
  connectinfo_start  String?   @db.VarChar(120)
  connectinfo_stop   String?   @db.VarChar(120)
  acctinputoctets    BigInt?
  acctoutputoctets   BigInt?
  calledstationid    String?   @db.VarChar(50)
  callingstationid   String?   @db.VarChar(50)
  acctterminatecause String?   @db.VarChar(32)
  servicetype        String?   @db.VarChar(32)
  framedprotocol     String?   @db.VarChar(32)
  framedipaddress    String?   @db.VarChar(15)
  tenantId           String?
  tenant             Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([acctsessionid])
  @@index([acctstarttime])
  @@index([acctstoptime])
  @@index([nasipaddress])
  @@index([tenantId])
  @@index([tenantId, acctstoptime])
  @@index([tenantId, username])
  @@index([tenantId, acctstarttime])
  @@index([nasipaddress, acctstoptime])
  @@map("radacct")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key])
  @@index([resetAt])
  @@map("rate_limits")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ServiceType {
  HOTSPOT
  PPPOE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  SUSPENDED
  BANNED
  DISABLED
  LIMITED
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum DurationUnit {
  MINUTES
  HOURS
  DAYS
  MONTHS
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

enum HotspotType {
  UNLIMITED
  DATA_CAPPED
}

enum PaymentType {
  PREPAID
  POSTPAID
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  EXTENDED
  SUSPENDED
}

enum OnlineStatus {
  ONLINE
  OFFLINE
}

enum TransactionType {
  MANUAL
  MOBILE
  VOUCHER
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
  EXPIRED
}

enum RouterStatus {
  ONLINE
  OFFLINE
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum VoucherStatus {
  UNUSED
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
  DRAFT
}

enum SmsStatus {
  SENT
  FAILED
  PENDING
}

enum SmsType {
  BROADCAST
  INDIVIDUAL
}

enum TemplateType {
  ACTIVATION
  EXPIRY
  PAYMENT
  CUSTOM
  REMINDER
}

enum ChannelStatus {
  ACTIVE
  INACTIVE
}

enum TenantStatus {
  PENDING_APPROVAL
  TRIALLING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TenantInvoiceStatus {
  PENDING
  PAID
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
