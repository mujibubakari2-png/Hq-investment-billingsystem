# Database
# IMPORTANT: Change port 5432 to match your actual PostgreSQL port!
DATABASE_URL="postgresql://kenge_user:kenge_password_replace_me@localhost:5432/kenge_isp"

# Auth
JWT_SECRET="generate-a-long-random-string-here-using-openssl-rand-hex-32"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# CORS
CORS_ORIGIN="http://localhost:5175,http://localhost:3001"

# ─── CRITICAL: App URL ───────────────────────────────────────────────────────
# Set this to your server's public IP or domain.
# If this is wrong/missing, payments are never confirmed and RADIUS rejects all users!
APP_URL="http://YOUR_DROPLET_PUBLIC_IP_OR_DOMAIN"
NEXT_PUBLIC_APP_URL="http://localhost:5173"

# Port
PORT=3000

# Environment
NODE_ENV="development"

# Notifications
ACCOUNT_NOTIFICATIONS_ENABLED=true
ACCOUNT_SMS_NOTIFICATIONS_ENABLED=false

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HQ INVESTMENT <your-email@gmail.com>"

# ─── Payment Webhooks ────────────────────────────────────────────────────────
# IMPORTANT: Set HOTSPOT_WEBHOOK_SECRET
# Without it, payment callbacks are blocked and users are never added to RADIUS!
HOTSPOT_WEBHOOK_SECRET="hotspot-secret-change-me"
PAYMENT_WEBHOOK_SECRET="shared-fallback-secret"
MPESA_WEBHOOK_SECRET="mpesa-secret"
AIRTELMONEY_WEBHOOK_SECRET="airtel-secret"
HALOPESA_WEBHOOK_SECRET="halopesa-secret"
TPESA_WEBHOOK_SECRET="tpesa-secret"
MIXBYYAS_WEBHOOK_SECRET="mixbyyas-secret"
PALMPESA_WEBHOOK_SECRET="palmpesa-secret"
ZENOPAY_WEBHOOK_SECRET="zenopay-secret"
HARAKAPAY_WEBHOOK_SECRET="harakapay-secret"
WEBHOOK_SECRET="generic-webhook-secret"

# Dev Features
ENABLE_SUPER_ADMIN_SETUP=true
ENABLE_TEST_MIKROTIK_LOGIC=true

# Migration Options (for troubleshooting only!)
SKIP_MIGRATIONS=false

# ─── MikroTik ────────────────────────────────────────────────────────────────
MIKROTIK_USE_HTTPS=false
MIKROTIK_TIMEOUT_MS=8000
MIKROTIK_INSECURE=false

# ─── WireGuard / RADIUS ──────────────────────────────────────────────────────
# WireGuard server tunnel IP — this is the IP MikroTik routers use as RADIUS address
# Set to the wg0 interface IP on your Droplet (check: ip addr show wg0)
WG_SERVER_IP=10.0.0.1

# Public IP of your Droplet — used by WireGuard peers to reach the server
# Shown in DigitalOcean dashboard as 'Public IP'
SERVER_PUBLIC_IP=174.138.42.168

# RADIUS NAS shared secret — must match clients.conf and MikroTik RADIUS settings
RADIUS_NAS_SECRET=kenge_radius_secret
