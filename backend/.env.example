# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# PostgreSQL connection string
# In Railway: This is auto-generated by the PostgreSQL plugin
DATABASE_URL="postgresql://user:password@localhost:5432/kenge_isp"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: openssl rand -hex 32
# Must be at least 32 characters. Use a unique value per deployment.
JWT_SECRET="replace-with-a-64-char-random-string"

# Environment: development | production
NODE_ENV="development"

# Google OAuth Client ID (from Google Cloud Console → APIs & Credentials)
# Required for Google Sign-In. Leave blank to disable Google login.
# IMPORTANT: Add the following to Authorized JavaScript Origins in GCP:
#   - http://localhost:5175      (development)
#   - https://your-frontend.railway.app  (Railway production)
GOOGLE_CLIENT_ID=""

# CORS — REQUIRED in production. The server will refuse to start without this.
# Set to your frontend domain. Do NOT use "*" in production.
# Example: CORS_ORIGIN="https://billing.hqinvestment.co.tz"
# In Railway: Set to your frontend service URL after deployment
CORS_ORIGIN=""

# Automation key — ONLY for CI/testing. NEVER set in production.
# AUTOMATION_KEY="your-ci-key-here"

# ─── Railway Deployment Notes ──────────────────────────────────────────────
# When deploying to Railway:
# 1. DATABASE_URL is auto-generated by Railway PostgreSQL plugin
# 2. JWT_SECRET: Generate a new random string for production
# 3. CORS_ORIGIN: Set to your Railway frontend URL after deployment
# 4. NODE_ENV: Set to "production" in Railway dashboard
