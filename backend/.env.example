# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# PostgreSQL connection string - REQUIRED
# Format: postgresql://username:password@host:port/database
# Examples:
#   Local: postgresql://postgres:password@localhost:5432/kenge_isp
#   Railway: postgresql://postgres:xxxx@containers-us-west-xxx.railway.app:xxxx/railway
# 
# In Railway: This is auto-generated by the PostgreSQL plugin and will be set automatically.
# DO NOT hardcode this - let Railway set it as an environment variable.
DATABASE_URL="postgresql://user:password@localhost:5432/kenge_isp"

# JWT Secret - REQUIRED - Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters and unique per deployment.
JWT_SECRET="replace-with-a-64-char-random-string"

# Environment - development | production
NODE_ENV="development"

# Google OAuth Client ID
# From: https://console.cloud.google.com/apis/credentials
# Add to Authorized JavaScript Origins:
#   - http://localhost:5175 (dev)
#   - https://your-frontend.railway.app (prod)
GOOGLE_CLIENT_ID="96960694156-pg7m1cjdqas9nelo83nicrq4ig3kuq3l.apps.googleusercontent.com"

# CORS Origin - REQUIRED in production
# Set to your frontend domain. DO NOT use "*" in production.
# Examples:
#   Development: http://localhost:5175
#   Railway: https://hq-frontend.up.railway.app
CORS_ORIGIN="https://hq-frontend.up.railway.app"

# Automation Key - ONLY for CI/testing. NEVER set in production.
# AUTOMATION_KEY="your-ci-key-here"

# Explicitly enable automation auth bypass in dev/test only.
# Keep this unset/false in production.
ALLOW_AUTOMATION_BYPASS="false"

# Account registration/approval notifications
# If true, system sends account status emails (created + approved)
ACCOUNT_NOTIFICATIONS_ENABLED="true"
# Optional login URL used inside notification messages
# ACCOUNT_PORTAL_URL="https://your-frontend-domain.com"
# If true, also log SMS notification messages for account events
ACCOUNT_SMS_NOTIFICATIONS_ENABLED="false"

# SMTP (required for email notifications)
# Example for Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="HQ INVESTMENT <your-email@gmail.com>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HQ INVESTMENT <your-email@gmail.com>"

# Shared fallback webhook secret for payment providers.
# Any configured provider-specific secret below takes precedence.
# PAYMENT_WEBHOOK_SECRET="replace-with-random-webhook-secret"

# Provider-specific webhook secrets (recommended for rotation isolation)
# MPESA_WEBHOOK_SECRET="replace-with-random-secret"
# AIRTELMONEY_WEBHOOK_SECRET="replace-with-random-secret"
# HALOPESA_WEBHOOK_SECRET="replace-with-random-secret"
# TPESA_WEBHOOK_SECRET="replace-with-random-secret"
# MIXBYYAS_WEBHOOK_SECRET="replace-with-random-secret"
# PALMPESA_WEBHOOK_SECRET="replace-with-random-secret"

# Shared hotspot callback webhook secret (optional)
# HOTSPOT_WEBHOOK_SECRET="replace-with-random-secret"
# ZENOPAY_WEBHOOK_SECRET="replace-with-random-secret"
# HARAKAPAY_WEBHOOK_SECRET="replace-with-random-secret"

# Generic webhook endpoint secret (/api/webhooks)
# WEBHOOK_SECRET="replace-with-random-secret"

# Super-admin setup/test endpoints are disabled by default.
ENABLE_SUPER_ADMIN_SETUP="false"
ENABLE_TEST_MIKROTIK_LOGIC="false"
# SUPER_ADMIN_SETUP_KEY="replace-with-random-secret"
# SUPER_ADMIN_EMAIL="admin@example.com"
# SUPER_ADMIN_PASSWORD="replace-with-strong-password"

# ─── Railway Deployment Notes ──────────────────────────────────────────────
# When deploying to Railway:
# 1. DATABASE_URL: Auto-set by Railway PostgreSQL plugin - DO NOT set manually
# 2. JWT_SECRET: Generate a new random string for production (min 32 chars)
# 3. CORS_ORIGIN: Must match your frontend URL on Railway
# 4. NODE_ENV: Set to "production" in Railway dashboard
# 5. GOOGLE_CLIENT_ID: Add Railway URLs to GCP Authorized Origins
