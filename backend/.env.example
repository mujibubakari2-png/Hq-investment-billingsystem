# ─────────────────────────────────────────────────────────────────────────────
# HQ INVESTMENT — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hqinvestment_user:CHANGE_ME@localhost:5432/hqinvestment_isp"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-a-long-random-string-here-using-openssl-rand-hex-32"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ─── App URLs ─────────────────────────────────────────────────────────────────
# CRITICAL: Set APP_URL to your server's public IP or domain.
# Payment providers POST webhooks to: {APP_URL}/api/webhooks/{provider}
# If this is wrong, payments are NEVER confirmed!
APP_URL="https://YOUR_DROPLET_PUBLIC_IP_OR_DOMAIN"
NEXT_PUBLIC_APP_URL="http://localhost:5173"

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5175,http://localhost:3001"

# ─── Port & Environment ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── Payment Environment ─────────────────────────────────────────────────────
# Set to "live" when ready for production payments
PAYMENT_ENVIRONMENT="sandbox"

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT PROVIDER CREDENTIALS
# Get credentials from each provider's developer portal.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PalmPesa ────────────────────────────────────────────────────────────────
# Developer portal: Contact Support@palmpesa.co.tz
# Webhooks will be sent to: {APP_URL}/api/webhooks/palmpesa
PALMPESA_API_URL="https://api.palmpesa.com/v1"
PALMPESA_API_KEY=""
PALMPESA_WEBHOOK_SECRET=""

# ─── ZenoPay ────────────────────────────────────────────────────────────────
# Developer portal: Email support@zenopay.net — requires KYC (BRELA, TIN, NIDA)
# Webhooks will be sent to: {APP_URL}/api/webhooks/zenopay
ZENOPAY_API_URL="https://zenoapi.com/api"
ZENOPAY_API_KEY=""
ZENOPAY_ACCOUNT_ID=""
ZENOPAY_WEBHOOK_SECRET=""

# ─── Mongike ────────────────────────────────────────────────────────────────
# Developer portal: https://mongike.com — register to get API credentials
# Webhooks will be sent to: {APP_URL}/api/webhooks/mongike
MONGIKE_API_URL="https://api.mongike.com/v1"
MONGIKE_API_KEY=""
MONGIKE_API_SECRET=""
MONGIKE_WEBHOOK_SECRET=""

# ─── HarakaPay ──────────────────────────────────────────────────────────────
# Developer portal: https://harakapayment.com or https://harakapay.net
# Webhooks will be sent to: {APP_URL}/api/webhooks/harakapay
HARAKAPAY_API_URL="https://api.harakapay.net/v1"
HARAKAPAY_API_KEY=""
HARAKAPAY_API_SECRET=""
HARAKAPAY_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK SECRETS (legacy / fallback)
# ─────────────────────────────────────────────────────────────────────────────
HOTSPOT_WEBHOOK_SECRET="hotspot-secret-CHANGE-ME"
PAYMENT_WEBHOOK_SECRET="shared-fallback-secret-CHANGE-ME"
MPESA_WEBHOOK_SECRET="mpesa-secret-CHANGE-ME"
AIRTELMONEY_WEBHOOK_SECRET="airtel-secret-CHANGE-ME"
HALOPESA_WEBHOOK_SECRET="halopesa-secret-CHANGE-ME"
TPESA_WEBHOOK_SECRET="tpesa-secret-CHANGE-ME"
MIXBYYAS_WEBHOOK_SECRET="mixbyyas-secret-CHANGE-ME"
WEBHOOK_SECRET="generic-webhook-secret-CHANGE-ME"

# ─── Notifications ───────────────────────────────────────────────────────────
ACCOUNT_NOTIFICATIONS_ENABLED=true
ACCOUNT_SMS_NOTIFICATIONS_ENABLED=false

# ─── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HQ INVESTMENT <your-email@gmail.com>"

# ─── Production Safety Flags ─────────────────────────────────────────────────
# CRITICAL: Keep both flags false in production!
ENABLE_SUPER_ADMIN_SETUP=false
ENABLE_TEST_MIKROTIK_LOGIC=false

# ─── Migration Options ───────────────────────────────────────────────────────
SKIP_MIGRATIONS=false

# ─── MikroTik ────────────────────────────────────────────────────────────────
MIKROTIK_USE_HTTPS=false
MIKROTIK_TIMEOUT_MS=8000
MIKROTIK_INSECURE=false

# ─── WireGuard / RADIUS ──────────────────────────────────────────────────────
WG_SERVER_IP=10.0.0.1
SERVER_PUBLIC_IP=YOUR_DROPLET_IP
RADIUS_NAS_SECRET=hqinvestment_radius_secret
