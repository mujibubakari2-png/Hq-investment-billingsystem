# Database
DATABASE_URL="postgresql://kenge_user:kenge_password_replace_me@localhost:5432/kenge_isp"

# Auth
JWT_SECRET="generate-a-long-random-string-here-using-openssl-rand-hex-32"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# CORS
CORS_ORIGIN="http://localhost:5175,http://localhost:3001"
APP_URL="http://localhost:5175"

# Environment
NODE_ENV="development"

# Notifications
ACCOUNT_NOTIFICATIONS_ENABLED=true
ACCOUNT_SMS_NOTIFICATIONS_ENABLED=false

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HQ INVESTMENT <your-email@gmail.com>"

# Payment Webhooks
PAYMENT_WEBHOOK_SECRET="shared-fallback-secret"
MPESA_WEBHOOK_SECRET="mpesa-secret"
AIRTELMONEY_WEBHOOK_SECRET="airtel-secret"
HALOPESA_WEBHOOK_SECRET="halopesa-secret"
TPESA_WEBHOOK_SECRET="tpesa-secret"
MIXBYYAS_WEBHOOK_SECRET="mixbyyas-secret"
PALMPESA_WEBHOOK_SECRET="palmpesa-secret"
HOTSPOT_WEBHOOK_SECRET="hotspot-secret"
ZENOPAY_WEBHOOK_SECRET="zenopay-secret"
HARAKAPAY_WEBHOOK_SECRET="harakapay-secret"
WEBHOOK_SECRET="generic-webhook-secret"

# Dev Features
ENABLE_SUPER_ADMIN_SETUP=true
ENABLE_TEST_MIKROTIK_LOGIC=true

# Migration Options (for troubleshooting only!)
# Set to true only if migrations are failing and you need to start the app temporarily
SKIP_MIGRATIONS=false
