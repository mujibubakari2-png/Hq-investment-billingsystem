# ─────────────────────────────────────────────────────────────────────────────
# HQ INVESTMENT — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME"

# ── App Configuration ─────────────────────────────────────────────────────────
# Set this to your actual domain (with https:// in production)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
APP_URL="https://yourdomain.com"
APP_NAME="HQ INVESTMENT"
NODE_ENV="development" # development | production | test

# ── Authentication & Security ─────────────────────────────────────────────────
# CRIT-006 FIX: Separate secrets for access tokens (2h) and refresh tokens (7d).
# Generate each: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT: These MUST be different from each other.
JWT_ACCESS_SECRET="REPLACE_ME_WITH_96_CHAR_HEX_STRING_UNIQUE_FOR_ACCESS_TOKENS"
JWT_REFRESH_SECRET="REPLACE_ME_WITH_96_CHAR_HEX_STRING_UNIQUE_FOR_REFRESH_TOKENS"
# Legacy fallback during migration — remove after all tokens have been re-issued
JWT_SECRET="REPLACE_ME_WITH_64_CHAR_HEX_STRING"
NEXTAUTH_SECRET="REPLACE_ME_WITH_64_CHAR_HEX_STRING"
JWT_EXPIRES_IN="2h"

# Field-Level Encryption (router passwords, payment API keys)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY="REPLACE_ME_WITH_64_CHAR_HEX_STRING"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGIN="https://yourdomain.com,http://localhost:5175"

# ── SMTP Settings (Email) ─────────────────────────────────────────────────────
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── SMS / Africa's Talking ────────────────────────────────────────────────────
AT_API_KEY="your-africas-talking-api-key"
AT_USERNAME="your-at-username"
AT_SENDER_ID="your-sender-id"

# ── RADIUS ────────────────────────────────────────────────────────────────────
RADIUS_SECRET="your-radius-secret"
RADIUS_HOST="127.0.0.1"
RADIUS_PORT="1812"

# ── MikroTik ──────────────────────────────────────────────────────────────────
MIKROTIK_USE_HTTPS="false"
MIKROTIK_INSECURE="false" # Only true for dev/isolated networks (disables TLS verification)
MIKROTIK_TIMEOUT_MS="8000"
# SEC-MK-002 FIX: Set to true ONLY in dev/lab environments.
# When false (default), HTTPS connections will NOT fall back to HTTP.
# A network attacker who drops HTTPS would be denied entirely rather than forcing cleartext.
MIKROTIK_ALLOW_HTTP_FALLBACK="false"

# ── Redis (required for BullMQ MikroTik job queue) ────────────────────────────
# Install: sudo apt install redis-server && sudo systemctl enable --now redis
# Default local: redis://127.0.0.1:6379
# Remote (DigitalOcean Managed Redis): rediss://<user>:<pass>@<host>:25061
REDIS_URL="redis://127.0.0.1:6379"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info" # debug | info | warn | error
# BetterStack (Logtail) for production log aggregation — get token from betterstack.com
LOGTAIL_SOURCE_TOKEN=""

# ── Payment Global Settings ───────────────────────────────────────────────────
PAYMENT_ENVIRONMENT="sandbox" # sandbox | live
PAYMENT_WEBHOOK_SECRET="global-webhook-secret-optional"
HOTSPOT_WEBHOOK_SECRET=""

# ── Payment Gateways (Set only the ones you use) ──────────────────────────────
# PalmPesa
PALMPESA_API_URL="https://palmpesa.drmlelwa.co.tz/api"
PALMPESA_API_KEY=""
PALMPESA_WEBHOOK_SECRET=""

# ZenoPay
ZENOPAY_API_URL="https://zenoapi.com/api"
ZENOPAY_API_KEY=""
ZENOPAY_ACCOUNT_ID=""
ZENOPAY_WEBHOOK_SECRET=""

# Mongike
MONGIKE_API_URL="https://api.mongike.com/v1"
MONGIKE_API_KEY=""
MONGIKE_API_SECRET=""
MONGIKE_WEBHOOK_SECRET=""

# HarakaPay
HARAKAPAY_API_URL="https://api.harakapay.net/v1"
HARAKAPAY_API_KEY=""
HARAKAPAY_API_SECRET=""
HARAKAPAY_WEBHOOK_SECRET=""

# M-Pesa (Daraja)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""
MPESA_CALLBACK_URL="https://yourdomain.com/api/webhooks/mpesa"
MPESA_WEBHOOK_SECRET=""

# Others (Airtel Money, HaloPesa, T-Pesa, MixByYas)
AIRTELMONEY_WEBHOOK_SECRET=""
HALOPESA_WEBHOOK_SECRET=""
TPESA_WEBHOOK_SECRET=""
MIXBYYAS_WEBHOOK_SECRET=""

# ── Stripe (International Card Payments) ──────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Test key starts with sk_test_..., live key with sk_live_...
STRIPE_SECRET_KEY=""
# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Starts with whsec_...
STRIPE_WEBHOOK_SECRET=""
# Currency for Stripe Checkout Sessions (USD, EUR, GBP, TZS, etc.)
STRIPE_CURRENCY="USD"
# Webhook URL to register in Stripe Dashboard:
#   https://yourdomain.com/api/webhooks/stripe
# Events to enable: checkout.session.completed, payment_intent.succeeded,
#   payment_intent.payment_failed, checkout.session.expired

# ── Flutterwave (African Multi-Currency Payments) ─────────────────────────────
# Get from: https://dashboard.flutterwave.com/dashboard/settings/apis
# Secret key starts with FLWSECK_...
FLUTTERWAVE_SECRET_KEY=""
# From Flutterwave Dashboard → Settings → Webhooks → Secret Hash
FLUTTERWAVE_WEBHOOK_HASH=""
# Override API base URL (default: https://api.flutterwave.com/v3)
FLUTTERWAVE_API_URL="https://api.flutterwave.com/v3"
# Default currency for Flutterwave charges
FLUTTERWAVE_CURRENCY="TZS"
# Optional: logo URL shown on hosted payment page
# NEXT_PUBLIC_APP_LOGO_URL="https://yourdomain.com/logo.png"
# Webhook URL to register in Flutterwave Dashboard:
#   https://yourdomain.com/api/webhooks/flutterwave
# Event to enable: charge.completed
